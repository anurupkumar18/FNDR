ANTHROPIC_API_KEY=your-api-key-here
# Graphiti / FalkorDB (optional, for knowledge graph features)
# OPENAI_API_KEY=your-openai-key-here
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=password

# MCP transport hardening
# FNDR_MCP_MODE=tunnel
# FNDR_MCP_REQUIRE_AUTH=true
# FNDR_MCP_ALLOW_LOOPBACK_AUTH_BYPASS=false
# FNDR_MCP_ENABLE_TLS=false
# FNDR_MCP_ALLOWED_ORIGINS=https://chat.openai.com,https://claude.ai
# FNDR_MCP_PUBLIC_BASE_URL=https://your-subdomain.trycloudflare.com
