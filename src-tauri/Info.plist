<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>FNDR</string>
    <key>CFBundleDisplayName</key>
    <string>FNDR</string>
    <key>CFBundleIdentifier</key>
    <string>com.fndr.app</string>
    <key>CFBundleVersion</key>
    <string>0.2.11</string>
    <key>CFBundleShortVersionString</key>
    <string>0.2.11</string>
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>
    
    <!-- Screen Recording Permission -->
    <key>NSScreenCaptureUsageDescription</key>
    <string>FNDR needs screen recording access to capture and index your screen content for intelligent search.</string>
    
    <!-- Accessibility Permission -->
    <key>NSAccessibilityUsageDescription</key>
    <string>FNDR needs accessibility access to detect focused fields and type local auto-fill results into apps you use.</string>

    <!-- Microphone Permission -->
    <key>NSMicrophoneUsageDescription</key>
    <string>FNDR needs microphone access for voice search and meeting transcription.</string>
    
    <!-- Run as background agent (menu bar app) -->
    <key>LSUIElement</key>
    <true/>
    
    <!-- Allow running at startup -->
    <key>LSBackgroundOnly</key>
    <false/>
</dict>
</plist>
