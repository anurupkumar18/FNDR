{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "fndr",
    "version": "0.2.11",
    "identifier": "com.fndr.app",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "FNDR",
                "width": 900,
                "height": 700,
                "resizable": true,
                "fullscreen": false,
                "transparent": false,
                "decorations": true,
                "center": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": [
            "dmg",
            "app"
        ],
        "resources": {
            "target/hermes-agent-bundle/": "hermes-agent/",
            "sidecar/parakeet_runner.py": "sidecar/parakeet_runner.py",
            "sidecar/fastvlm_runner.py": "sidecar/fastvlm_runner.py",
            "sidecar/whisper_gguf_runner.py": "sidecar/whisper_gguf_runner.py",
            "sidecar/orpheus_tts_runner.py": "sidecar/orpheus_tts_runner.py",
            "sidecar/minilm_embedder.py": "sidecar/minilm_embedder.py"
        },
        "icon": [
            "icons/icon.png",
            "icons/icon.icns"
        ],
        "macOS": {
            "entitlements": "Entitlements.plist",
            "infoPlist": "Info.plist",
            "minimumSystemVersion": "13.0"
        }
    }
}
